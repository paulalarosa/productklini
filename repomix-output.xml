        .eq("project_id", projectId)
        .order("last_activity", { ascending: false });
      
      if (error) throw error;
      return data;
    },
    enabled: !!projectId,
  });
}

export function useUserAchievements(projectId?: string) {
  return useQuery({
    queryKey: ["user-achievements", projectId],
    queryFn: async () => {
      if (!projectId) return [];
      
      const { data, error } = await supabase
