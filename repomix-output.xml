    queryKey: ["achievement-definitions"],
    queryFn: async () => {
      const { data, error } = await supabase
        .from("achievement_definitions")
        .select("*")
        .order("points", { ascending: true });
      
      if (error) throw error;
      return data;
    },
  });
}

export function useUserProgress(projectId?: string) {
