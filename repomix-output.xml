    cssCode: `@keyframes fadeOutDown {\n  from { opacity: 1; transform: translateY(0); }\n  to { opacity: 0; transform: translateY(20px); }\n}\n.fade-out-down { animation: fadeOutDown 0.3s ease-in forwards; }`,
