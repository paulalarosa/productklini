            <button
              onClick={() => setShowImport(!showImport)}
              className="flex items-center gap-1.5 text-[10px] px-2.5 py-1.5 rounded-lg bg-primary/10 text-primary border border-primary/20 hover:bg-primary/20 transition-colors"
            >
              <Download size={10} />
              Importar Reviews
