        {/* Row 1 */}
        <div className="md:col-span-1">
          <CanvasSection
            title="Parceiros Principais"
            items={(canvas.key_partners as string[]) || []}
            onAddItem={(item) => addItem("key_partners", item)}
            onRemoveItem={(index) => removeItem("key_partners", index)}
