      if (!projectId) return [];
      const { data, error } = await supabase.from("moodboards").select("*").eq("project_id", projectId).order("created_at", { ascending: false });
      if (error) throw error;
      return data;
    },
    enabled: !!projectId,
  });

  const handleAdd = async () => {
    if (!form.title.trim() || !projectId) return;
