<file path="src/index.css">
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --background: 228 14% 8%;
    --foreground: 210 20% 92%;

    --card: 228 12% 11%;
    --card-foreground: 210 20% 92%;

    --popover: 228 12% 11%;
    --popover-foreground: 210 20% 92%;

