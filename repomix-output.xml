              {group.title}
              <ChevronDown
                className={`w-3 h-3 transition-transform ${collapsed[`${group.title}-${gi}`] ? "-rotate-90" : ""}`}
              />
            </button>
            {!collapsed[`${group.title}-${gi}`] && (
              <div className="space-y-0.5">
                {group.items.map((item) => {
